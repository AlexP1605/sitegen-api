# ==========================================
# SiteGen API - Configuration
# ==========================================
# Copier ce fichier en .env et remplir les valeurs

# Port du serveur
PORT=3000

# Clé API Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Clé API de ton SaaS (à générer toi-même, ex: openssl rand -hex 32)
# Cette clé sera demandée dans le header X-Api-Key de chaque requête
SITEGEN_API_KEY=ta-cle-api-secrete-ici

# Environnement
NODE_ENV=production
